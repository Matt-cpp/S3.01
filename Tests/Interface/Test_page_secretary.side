  "tests": [
    {
      "id": "11111111-1111-4111-8111-111111111111",
      "name": "sec_login_dashboard",
      "commands": [
        {
          "id": "c1-1",
          "command": "open",
          "target": "/Presenter/shared/logout_presenter.php",
          "value": ""
        },
        {
          "id": "c1-2",
          "command": "open",
          "target": "/View/templates/shared/login.php",
          "value": ""
        },
        {
          "id": "c1-3",
          "command": "waitForElementPresent",
          "target": "id=email",
          "value": "10000"
        },
        {
          "id": "c1-4",
          "command": "waitForElementPresent",
          "target": "id=password",
          "value": "10000"
        },
        {
          "id": "c1-5",
          "command": "executeScript",
          "target": "window.loginStartTime = performance.now();",
          "value": ""
        },
        {
          "id": "c1-5a",
          "command": "executeScript",
          "target": "const e=document.querySelector('#email'); if(!e) throw new Error('email introuvable URL='+location.href); e.value='secretaire@uphf.fr'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "value": ""
        },
        {
          "id": "c1-6",
          "command": "executeScript",
          "target": "const p=document.querySelector('#password'); if(!p) throw new Error('password introuvable URL='+location.href); p.value='secretaire'; p.dispatchEvent(new Event('input',{bubbles:true})); p.dispatchEvent(new Event('change',{bubbles:true}));",
          "value": ""
        },
        {
          "id": "c1-7",
          "command": "click",
          "target": "css=button[type='submit']",
          "value": ""
        },
        {
          "id": "c1-8",
          "command": "waitForElementVisible",
          "target": "id=manual-absence-form",
          "value": "10000"
        },
        {
          "id": "c1-8a",
          "command": "executeScript",
          "target": "const loadTime = performance.now() - window.loginStartTime; if(loadTime > 5000) console.warn('Login took ' + loadTime + 'ms'); window.loginLoadTime = loadTime;",
          "value": ""
        },
        {
          "id": "c1-9",
          "command": "assertElementPresent",
          "target": "id=import-history",
          "value": ""
        },
        {
          "id": "c1-10",
          "command": "executeScript",
          "target": "if(!location.pathname.includes('/View/templates/secretary/home.php')) throw new Error('URL KO: '+location.href);",
          "value": ""
        }
      ]
    },
