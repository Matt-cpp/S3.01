    {
      "id": "66666666-6666-4666-8666-666666666666",
      "name": "mgr_login_dashboard",
      "commands": [
        {
          "id": "c6-1",
          "command": "open",
          "target": "/Presenter/shared/logout_presenter.php",
          "value": ""
        },
        {
          "id": "c6-2",
          "command": "open",
          "target": "/View/templates/shared/login.php",
          "value": ""
        },
        {
          "id": "c6-3",
          "command": "waitForElementPresent",
          "target": "id=email",
          "value": "10000"
        },
        {
          "id": "c6-4",
          "command": "waitForElementPresent",
          "target": "id=password",
          "value": "10000"
        },
        {
          "id": "c6-5",
          "command": "executeScript",
          "target": "window.mgrLoginStart = performance.now();",
          "value": ""
        },
        {
          "id": "c6-5a",
          "command": "executeScript",
          "target": "const e=document.querySelector('#email'); if(!e) throw new Error('email introuvable URL='+location.href); e.value='academic_manager@uphf.fr'; e.dispatchEvent(new Event('input',{bubbles:true})); e.dispatchEvent(new Event('change',{bubbles:true}));",
          "value": ""
        },
        {
          "id": "c6-6",
          "command": "executeScript",
          "target": "const p=document.querySelector('#password'); if(!p) throw new Error('password introuvable URL='+location.href); p.value='academic_manager'; p.dispatchEvent(new Event('input',{bubbles:true})); p.dispatchEvent(new Event('change',{bubbles:true}));",
          "value": ""
        },
        {
          "id": "c6-7",
          "command": "click",
          "target": "css=button[type='submit']",
          "value": ""
        },
        {
          "id": "c6-8",
          "command": "waitForElementVisible",
          "target": "css=.stats-grid",
          "value": "10000"
        },
        {
          "id": "c6-8a",
          "command": "executeScript",
          "target": "const mgrLoadTime = performance.now() - window.mgrLoginStart; if(mgrLoadTime > 5000) console.warn('Manager login took ' + mgrLoadTime + 'ms'); window.mgrLoadTime = mgrLoadTime;",
          "value": ""
        },
        {
          "id": "c6-9",
          "command": "assertElementPresent",
          "target": "css=.quick-actions",
          "value": ""
        },
        {
          "id": "c6-10",
          "command": "executeScript",
          "target": "if(!location.pathname.includes('/View/templates/academic_manager/home.php')) throw new Error('URL KO: '+location.href);",
          "value": ""
        }
      ]
    },
